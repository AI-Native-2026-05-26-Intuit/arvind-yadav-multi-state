MULTISTATE_AI_PROXY_BASE_URL=https://proxy.example.internal
MULTISTATE_AI_PROXY_API_KEY=key_synth_replace_me
MULTISTATE_AI_TENANT_ID=tenant-a
MULTISTATE_AI_LOG_LEVEL=INFO

# W7 D2 — LangSmith / Postgres / evaluator (placeholders only; never commit real keys)
MULTISTATE_AI_LANGSMITH_API_KEY=replace_me_langsmith_key
MULTISTATE_AI_LANGSMITH_PROJECT=multistate-ai-dev
# Optional: only if you call dsn_from_env() / retrieve_chunks_from_env().
# Pytest and the LangSmith assert script use Testcontainers when this is unset.
MULTISTATE_AI_PG_DSN=postgresql://multistate:multistate@localhost:5432/multistate
MULTISTATE_AI_ANTHROPIC_API_KEY=replace_me_anthropic_key
# Optional RAGAS evaluator model override (default: claude-haiku-4-5-20251001)
# MULTISTATE_AI_RAGAS_MODEL=claude-haiku-4-5-20251001

# Runtime env names expected by langsmith / ragas (map from the MULTISTATE_AI_* values above):
# LANGSMITH_API_KEY=...          # same value as MULTISTATE_AI_LANGSMITH_API_KEY
# LANGSMITH_PROJECT=multistate-ai-dev
# LANGSMITH_TRACING=true
# ANTHROPIC_API_KEY=...          # same value as MULTISTATE_AI_ANTHROPIC_API_KEY
# Optional macOS corp TLS:
# SSL_CERT_FILE=/etc/ssl/cert.pem
# REQUESTS_CA_BUNDLE=/etc/ssl/cert.pem
