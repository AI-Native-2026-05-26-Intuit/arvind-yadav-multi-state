MULTISTATE_MCP_JWT_SECRET=dev-only-multistate-mcp-hs256
LANGSMITH_API_KEY=REPLACE_WITH_LANGSMITH_API_KEY_FROM_KEYCHAIN
LANGSMITH_PROJECT=multistate-mcp-server
