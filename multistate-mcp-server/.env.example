# multistate-mcp-server/.env.example
# Copy to .env (never commit .env). Placeholders only.

MULTISTATE_MCP_BEARER_JWT=REPLACE_WITH_BEARER_FROM_KEYCHAIN
MULTISTATE_MCP_ORDERS_SVC_URL=https://multistate-orders.internal
MULTISTATE_MCP_LLM_PROXY_URL=https://llm-proxy.internal
MULTISTATE_MCP_HOST=0.0.0.0
MULTISTATE_MCP_PORT=8080
MULTISTATE_MCP_JWT_ISSUER=https://idp.example.internal/realms/uptimecrew
MULTISTATE_MCP_JWT_AUDIENCE=multistate-mcp-server
