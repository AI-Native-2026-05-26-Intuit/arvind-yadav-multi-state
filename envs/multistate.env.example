# envs/multistate.env.example
# Copy to envs/multistate.env (gitignored) and fill in any blanks.
# Compose substitutes ${VAR} references in compose.yaml from this file.

# ----- App ------------------------------------------------------------
APP_VERSION=0.1.0
SPRING_PROFILES_ACTIVE=local

# ----- Postgres -------------------------------------------------------
# The DB name + user are read by the postgres service from compose.yaml;
# the password comes from ./secrets/pg_password.txt via Compose secrets,
# never an env var. Keep this file free of plaintext credentials.
POSTGRES_DB=multistate_dev
POSTGRES_USER=multistate_dev

# ----- Redis ----------------------------------------------------------
SPRING_DATA_REDIS_HOST=redis
SPRING_DATA_REDIS_PORT=6379

# ----- Kafka ----------------------------------------------------------
SPRING_KAFKA_BOOTSTRAP_SERVERS=kafka:9092
SPRING_KAFKA_CONSUMER_GROUP_ID=multistate-local

# ----- OTel (W5 D5 forward hook) --------------------------------------
OTEL_EXPORTER_OTLP_ENDPOINT=http://otelcol:4317
OTEL_SERVICE_NAME=multistate-api

# ----- Required (no default; fails fast if missing) -------------------
# Use the ${VAR:?error} form in compose.yaml so a missing value aborts
# the stack at parse time rather than 30 s into startup.
# Example: image: uptimecrew/multistate-api:${APP_VERSION:?APP_VERSION required}
