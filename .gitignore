.gradle/
build/
out/
.idea/
.vscode/
*.iml
bin/

# SAM build state (W5 D4). NEVER commit any of these.
.aws-sam/
samconfig.toml
events/*.local.json
/tmp/sam-smoke-body
target/
env.json

# Local-dev secrets (compose secrets:)
secrets/*
!secrets/.gitkeep

# Local-dev env (commit the .example template only)
envs/*.env
!envs/*.env.example

# Compose smoke / CI failure artifact
compose-logs.txt

# Kubernetes-managed dev state (W5 D3). NEVER commit any of these.
manifests/*.local.yaml
pod-logs.txt
.k3d/

# Observability artefacts the build / CI tooling produces (W5 D5).
# Generated dashboards from `grafana export` go here; only the
# authoritative .grafana/dashboards/*.json belongs in git.
.grafana/exported/
sloth-out/
/tmp/observability-smoke-*

# OTel agent jar fetched by docker/otel/fetch-agent.sh (not committed; ~20 MB)
docker/otel/opentelemetry-javaagent.jar
docker/staging/